# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/placeai
DIRECT_URL=postgresql://user:password@host:5432/placeai

# ── Auth (Clerk) ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI Services ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Vector DB (Pinecone) ───────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=placeai-jobs
PINECONE_ENVIRONMENT=...

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── Storage (Cloudflare R2) ────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=placeai-resumes
CLOUDFLARE_R2_PUBLIC_URL=https://files.placeai.in

# ── Payments ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Email ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@placeai.in

# ── Analytics ──────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
SENTRY_ORG=placeai
SENTRY_PROJECT=placeai-web

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=dev-secret-change-in-production
NEXTAUTH_SECRET=dev-secret-change-in-production

# ── Feature Flags ──────────────────────────────────────────────────────
FEATURE_VOICE_INTERVIEW=false
FEATURE_REFERRAL_ENGINE=true
FEATURE_LINKEDIN_IMPORT=false
