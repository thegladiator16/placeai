# ─── Database ────────────────────────────────────────────────────────────────
# Use docker-compose postgres for local dev
DATABASE_URL="postgresql://placeai:placeai_dev_password@localhost:5432/placeai"
DIRECT_URL="postgresql://placeai:placeai_dev_password@localhost:5432/placeai"

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
# Get from https://clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SECRET="whsec_xxx"

# ─── AI ───────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxx"

# ─── Vector Database (Pinecone) ───────────────────────────────────────────────
# Get from https://pinecone.io
PINECONE_API_KEY="pck_xxx"
PINECONE_INDEX_NAME="placeai-jobs"

# ─── Caching (Redis / Upstash) ────────────────────────────────────────────────
# Local: use docker-compose redis via ioredis, not Upstash REST client
UPSTASH_REDIS_REST_URL="http://localhost:6379"
UPSTASH_REDIS_REST_TOKEN="local_dev"

# ─── File Storage (Cloudflare R2) ─────────────────────────────────────────────
# Get from https://dash.cloudflare.com → R2
CLOUDFLARE_R2_ACCOUNT_ID="xxx"
CLOUDFLARE_R2_ACCESS_KEY_ID="xxx"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="xxx"
CLOUDFLARE_R2_BUCKET_NAME="placeai-resumes"
CLOUDFLARE_R2_PUBLIC_URL="https://files.local.example.com"

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxx"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from https://resend.com
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="noreply@placeai.local"

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ─── Analytics & Observability (optional for local dev) ───────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_AUTH_TOKEN="xxx"
